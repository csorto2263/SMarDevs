# ============================================================
# SMarDevs.com Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Supabase (REQUIRED) ──
# Get these from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Calendly (optional) ──
# Your Calendly scheduling link for the "Book a Call" embed
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/smartdevs/consultation

# ── Contact Form (optional) ──
# If using an external form handler (e.g., HubSpot, Formspree)
# NEXT_PUBLIC_FORM_ENDPOINT=https://formspree.io/f/your_form_id

# ── Analytics (optional) ──
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Site URL ──
NEXT_PUBLIC_SITE_URL=https://smartdevs.com
